{
  "services": {
    "api": {
      "path": ".",
      "dockerfile": "Dockerfile.server",
      "port": 8080,
      "cpu": 256,
      "memory": 512
    },
    "web": {
      "path": ".",
      "dockerfile": "Dockerfile",
      "port": 8080,
      "cpu": 256,
      "memory": 512,
      "buildArgs": {
        "VITE_API_URL": "${{api.URL}}"
      }
    }
  }
}
